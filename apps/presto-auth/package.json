{
	"name": "@tempo/presto-auth",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"dev": "wrangler dev",
		"build": "wrangler deploy --dry-run --outdir dist",
		"build:wheel": "./scripts/build-wheel.sh",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"test": "vitest run --passWithNoTests",
		"deploy:preview": "wrangler deploy --env preview",
		"deploy:testnet": "wrangler deploy --env testnet",
		"deploy:moderato": "wrangler deploy --env moderato",
		"deploy:mainnet": "wrangler deploy --env mainnet"
	},
	"dependencies": {
		"hono": "^4.6.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.5.0",
		"@cloudflare/workers-types": "^4.20250115.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.0",
		"wrangler": "^4.59.2"
	}
}
