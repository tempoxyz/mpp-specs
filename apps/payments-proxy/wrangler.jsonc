{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "payments-proxy",
	"main": "src/index.ts",
	"compatibility_date": "2025-01-15",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": false,
	"preview_urls": true,
	"keep_vars": true,
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true,
			"persist": true
		}
	},

	// Default vars inherited by all environments
	"vars": {
		"ENVIRONMENT": "development",
		"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
		"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
		"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD",
		"BROWSERBASE_API_KEY": "REDACTED_BROWSERBASE_KEY",
		"EXA_API_KEY": "exa-placeholder-key",
		"FIRECRAWL_API_KEY": "REDACTED_FIRECRAWL_KEY",
		"OPENROUTER_API_KEY": "REDACTED_OPENROUTER_KEY",
		"TWITTER_BEARER_TOKEN": "twitter-placeholder-token"
	},

	"env": {
		"preview": {
			"name": "payments-proxy-preview",
			"workers_dev": true,
			"vars": {
				"ENVIRONMENT": "preview"
			}
		},
		// Canonical testnet - *.payments.testnet.tempo.xyz
		"testnet": {
			"name": "payments-proxy-testnet",
			"routes": [
				{ "pattern": "*.payments.testnet.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true }
			],
			"vars": {
				"ENVIRONMENT": "testnet",
				"TEMPO_RPC_URL": "https://rpc.testnet.tempo.xyz"
			}
		},
		// Moderato chain-specific - *.payments.moderato.tempo.xyz
		"moderato": {
			"name": "payments-proxy-moderato",
			"routes": [
				{ "pattern": "*.payments.moderato.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true }
			],
			"vars": {
				"ENVIRONMENT": "moderato"
				// TEMPO_RPC_URL inherited from top-level (moderato)
			}
		},
		// Mainnet production - *.payments.tempo.xyz
		"mainnet": {
			"name": "payments-proxy-mainnet",
			"routes": [
				{ "pattern": "*.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true }
			],
			"vars": {
				"ENVIRONMENT": "mainnet",
				"TEMPO_RPC_URL": "https://rpc.tempo.xyz"
			}
			// Note: For mainnet, set API keys via wrangler secret:
			// wrangler secret put BROWSERBASE_API_KEY --env mainnet
			// wrangler secret put EXA_API_KEY --env mainnet
			// wrangler secret put FIRECRAWL_API_KEY --env mainnet
			// wrangler secret put OPENROUTER_API_KEY --env mainnet
			// wrangler secret put TWITTER_BEARER_TOKEN --env mainnet
		}
	}
}
