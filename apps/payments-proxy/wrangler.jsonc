{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "payments-proxy",
	"main": "src/index.ts",
	"compatibility_date": "2025-01-15",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"vars": {
		"TEMPO_RPC_URL": "https://rpc.tempo.xyz"
	},
	"assets": {
		"directory": "./public",
		"binding": "ASSETS"
	},
	"routes": [
		{ "pattern": "payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "anthropic.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "claude.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{
			"pattern": "browserbase.payments.tempo.xyz",
			"zone_name": "tempo.xyz",
			"custom_domain": true
		},
		{ "pattern": "exa.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "firecrawl.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "openai.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "gpt.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "codex.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "openrouter.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "llm.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "twitter.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "modal.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "gpu.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "compute.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "rpc.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true },
		{ "pattern": "chain.payments.tempo.xyz", "zone_name": "tempo.xyz", "custom_domain": true }
	]
}
