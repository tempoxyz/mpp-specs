{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "payments-proxy",
	"main": "src/index.ts",
	"compatibility_date": "2025-01-15",
	"compatibility_flags": ["nodejs_compat"],

	"vars": {
		"ENVIRONMENT": "development",
		"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
		"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
		"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD",
		"BROWSERBASE_API_KEY": "REDACTED_BROWSERBASE_KEY",
		"EXA_API_KEY": "exa-placeholder-key",
		"FIRECRAWL_API_KEY": "REDACTED_FIRECRAWL_KEY",
		"OPENROUTER_API_KEY": "REDACTED_OPENROUTER_KEY",
		"TWITTER_BEARER_TOKEN": "twitter-placeholder-token"
	},

	"env": {
		"preview": {
			"name": "payments-proxy-preview",
			"vars": {
				"ENVIRONMENT": "preview",
				"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
				"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
				"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD",
				"BROWSERBASE_API_KEY": "REDACTED_BROWSERBASE_KEY",
				"EXA_API_KEY": "exa-placeholder-key",
				"FIRECRAWL_API_KEY": "REDACTED_FIRECRAWL_KEY",
				"OPENROUTER_API_KEY": "REDACTED_OPENROUTER_KEY",
				"TWITTER_BEARER_TOKEN": "twitter-placeholder-token"
			}
		},
		// Testnet deployment - canonical testnet + moderato-specific routes
		"moderato": {
			"name": "payments-proxy-moderato",
			"vars": {
				"ENVIRONMENT": "moderato",
				"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
				"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
				"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD",
				"BROWSERBASE_API_KEY": "REDACTED_BROWSERBASE_KEY",
				"EXA_API_KEY": "exa-placeholder-key",
				"FIRECRAWL_API_KEY": "REDACTED_FIRECRAWL_KEY",
				"OPENROUTER_API_KEY": "REDACTED_OPENROUTER_KEY",
				"TWITTER_BEARER_TOKEN": "twitter-placeholder-token"
			}
		},
		// Production deployment
		"presto": {
			"name": "payments-proxy-presto",
			"vars": {
				"ENVIRONMENT": "presto",
				"TEMPO_RPC_URL": "https://rpc.presto.tempo.xyz",
				"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
				"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD",
				"BROWSERBASE_API_KEY": "REDACTED_BROWSERBASE_KEY",
				"EXA_API_KEY": "exa-placeholder-key",
				"FIRECRAWL_API_KEY": "REDACTED_FIRECRAWL_KEY",
				"OPENROUTER_API_KEY": "REDACTED_OPENROUTER_KEY",
				"TWITTER_BEARER_TOKEN": "twitter-placeholder-token"
			}
		},
		"production": {
			"name": "payments-proxy-production",
			"routes": [
				{ "pattern": "*.payments.tempo.xyz/*", "zone_name": "tempo.xyz" }
			],
			"vars": {
				"ENVIRONMENT": "production",
				"TEMPO_RPC_URL": "https://rpc.moderato.tempo.xyz",
				"TEMPO_RPC_USERNAME": "REDACTED_USERNAME",
				"TEMPO_RPC_PASSWORD": "REDACTED_PASSWORD"
			}
			// Note: For production, set API keys via wrangler secret:
			// wrangler secret put BROWSERBASE_API_KEY --env production
			// wrangler secret put EXA_API_KEY --env production
			// wrangler secret put FIRECRAWL_API_KEY --env production
			// wrangler secret put OPENROUTER_API_KEY --env production
			// wrangler secret put TWITTER_BEARER_TOKEN --env production
		}
	}
}
