{
	"name": "@tempo/payments-proxy",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"dev": "wrangler dev",
		"build": "wrangler deploy --dry-run --outdir dist",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"deploy:preview": "wrangler deploy --env preview",
		"deploy:moderato": "wrangler deploy --env moderato",
		"deploy:presto": "wrangler deploy --env presto"
	},
	"dependencies": {
		"@tempo/paymentauth-protocol": "workspace:*",
		"@tempo/shared": "workspace:*",
		"hono": "^4.6.0",
		"viem": "^2.30.6",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.5.0",
		"@cloudflare/workers-types": "^4.20250115.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.0",
		"wrangler": "^3.99.0"
	}
}
