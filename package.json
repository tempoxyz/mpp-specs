{
	"name": "tempo-ai-payments",
	"private": true,
	"packageManager": "pnpm@10.28.0",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"create-app": "npx ts-node scripts/create-app.ts",
		"dev": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"check": "pnpm check:biome && pnpm typecheck",
		"check:biome": "biome check --write --unsafe",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"test": "vitest run && turbo test",
		"test:repo": "vitest run",
		"test:apps": "turbo test",
		"test:coverage": "turbo test:coverage",
		"deploy:preview": "turbo deploy:preview",
		"deploy:prod": "turbo deploy:prod",
		"clean": "turbo clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@cloudflare/workers-types": "^4.20250115.0",
		"turbo": "^2.4.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.0",
		"wrangler": "^3.99.0",
		"yaml": "^2.6.1"
	}
}
