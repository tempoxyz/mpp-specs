{
	"name": "tempo-ai-payments",
	"private": true,
	"packageManager": "pnpm@10.28.0",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"create-app": "npx ts-node scripts/create-app.ts",
		"dev": "pnpm -r --parallel dev",
		"build": "pnpm -r build",
		"typecheck": "pnpm -r typecheck",
		"check": "pnpm check:biome && pnpm typecheck",
		"check:biome": "biome check --write --unsafe",
		"lint": "pnpm -r lint",
		"lint:fix": "pnpm -r lint:fix",
		"test": "vitest run && pnpm -r test",
		"test:repo": "vitest run",
		"test:apps": "pnpm -r test",
		"test:coverage": "pnpm -r test:coverage",
		"deploy:preview": "pnpm -r deploy:preview",
		"deploy:prod": "pnpm -r deploy:prod",
		"clean": "pnpm -r clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@cloudflare/workers-types": "^4.20250115.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.0",
		"wrangler": "^3.99.0",
		"yaml": "^2.6.1"
	}
}
